{
  "commands": [
    {
      "command": "trainning_extension.refreshLogs",
      "title": "Refresh Logs",
      "icon": "$(refresh)"
    },
    {
      "command": "trainning_extension.copyOnnxFiles",
      "title": "Copy",
      "icon": "$(files)"
    },
    {
      "command": "trainning_extension.revealOnnxInExplorer",
      "title": "Reveal in File Explorer"
    },
    {
      "command": "trainning_extension.copyOnnxFilePath",
      "title": "Copy Path"
    },
    {
      "command": "trainning_extension.copyRelativeLogPath",
      "title": "Copy Relative Path"
    },
    {
      "command": "trainning_extension.copyLogFileName",
      "title": "Copy File Name"
    },
    {
      "command": "trainning_extension.compareSelectedLogFiles",
      "title": "Compare Selected File",
      "icon": "$(diff)"
    }
  ],
  "keybindings": [
    {
      "command": "trainning_extension.copyOnnxFilePath",
      "key": "ctrl+alt+c",
      "when": "focusedView == trainning_extension_logs"
    },
    {
      "command": "trainning_extension.copyRelativeLogPath",
      "key": "ctrl+shift+alt+c",
      "when": "focusedView == trainning_extension_logs"
    }
  ],
  "views": {
    "trainning_extension": [
      {
        "id": "trainning_extension_logs",
        "name": "Logs"
      }
    ]
  },
  "menus": {
    "view/title": [
      {
        "command": "trainning_extension.refreshLogs",
        "when": "view == trainning_extension_logs",
        "group": "navigation@2"
      },
      {
        "command": "trainning_extension.copyOnnxFiles",
        "when": "view == trainning_extension_logs",
        "group": "navigation@3"
      }
    ],
    "view/item/context": [
      {
        "command": "trainning_extension.copyOnnxFiles",
        "when": "view == trainning_extension_logs && viewItem == runFile",
        "group": "inline@1"
      },
      {
        "command": "trainning_extension.copyOnnxFiles",
        "when": "view == trainning_extension_logs && viewItem == runFile",
        "group": "navigation@1"
      },
      {
        "command": "trainning_extension.copyOnnxFilePath",
        "when": "view == trainning_extension_logs && viewItem == runFile",
        "group": "navigation@2"
      },
      {
        "command": "trainning_extension.copyRelativeLogPath",
        "when": "view == trainning_extension_logs && viewItem == runFile",
        "group": "navigation@3"
      },
      {
        "command": "trainning_extension.copyLogFileName",
        "when": "view == trainning_extension_logs && viewItem == runFile",
        "group": "navigation@4"
      },
      {
        "command": "trainning_extension.revealOnnxInExplorer",
        "when": "view == trainning_extension_logs && viewItem == runFile",
        "group": "navigation@5"
      },
      {
        "command": "trainning_extension.compareSelectedLogFiles",
        "when": "view == trainning_extension_logs && viewItem == runFile",
        "group": "navigation@6"
      },
      {
        "command": "trainning_extension.copyOnnxFiles",
        "when": "view == trainning_extension_logs && viewItem == runDirectory",
        "group": "inline@1"
      },
      {
        "command": "trainning_extension.copyOnnxFiles",
        "when": "view == trainning_extension_logs && viewItem == runDirectory",
        "group": "navigation@1"
      },
      {
        "command": "trainning_extension.copyOnnxFilePath",
        "when": "view == trainning_extension_logs && viewItem == runDirectory",
        "group": "navigation@2"
      },
      {
        "command": "trainning_extension.copyRelativeLogPath",
        "when": "view == trainning_extension_logs && viewItem == runDirectory",
        "group": "navigation@3"
      },
      {
        "command": "trainning_extension.copyLogFileName",
        "when": "view == trainning_extension_logs && viewItem == runDirectory",
        "group": "navigation@4"
      },
      {
        "command": "trainning_extension.revealOnnxInExplorer",
        "when": "view == trainning_extension_logs && viewItem == runDirectory",
        "group": "navigation@5"
      },
      {
        "command": "trainning_extension.copyOnnxFiles",
        "when": "view == trainning_extension_logs && viewItem == runFolder",
        "group": "inline@1"
      },
      {
        "command": "trainning_extension.copyOnnxFiles",
        "when": "view == trainning_extension_logs && viewItem == runFolder",
        "group": "navigation@1"
      },
      {
        "command": "trainning_extension.copyOnnxFilePath",
        "when": "view == trainning_extension_logs && viewItem == runFolder",
        "group": "navigation@2"
      },
      {
        "command": "trainning_extension.copyRelativeLogPath",
        "when": "view == trainning_extension_logs && viewItem == runFolder",
        "group": "navigation@3"
      },
      {
        "command": "trainning_extension.copyLogFileName",
        "when": "view == trainning_extension_logs && viewItem == runFolder",
        "group": "navigation@4"
      },
      {
        "command": "trainning_extension.revealOnnxInExplorer",
        "when": "view == trainning_extension_logs && viewItem == runFolder",
