{
  "parameters": {
    "gpu_ids": {
      "type": "select",
      "prompt": "请选择一个 GPU",
      "options": ["0", "1", "2", "3"]
    }
  },
  "commands": [
    {
      "name": "NVIDIA SMI",
      "command": "nvidia-smi"
    },
    {
      "name": "SHA256 Checksum (Recursive)",
      "command": "find . -type f -print0 | xargs -0 -P\"$(nproc)\" -n1 sha256sum | LC_ALL=C sort --parallel=\"$(nproc)\" -S 25% | sha256sum"
    },
    {
      "name": "task",
      "command": "CUDA_VISIBLE_DEVICES={gpu_ids} uv run train task --env.scene.num-envs 4096"
    },
    {
      "name": "本地到mjlab服务器",
      "command": "rsync -avz --delete --exclude='build/' --exclude='devel/'  --exclude='.venv/' --exclude='logs/' --exclude='wandb/' /home/user/mjlab/ ssh_server:/home/user/mjlab/ "
    },
    {
      "name": "mjlab服务器logs到本地",
      "command": "rsync -avz --progress --delete ssh_user@ssh_server:/home/user/mjlab/logs/ /home/user/mjlab/logs/"
    }
  ]
}
