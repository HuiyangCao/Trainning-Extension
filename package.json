{
  "name": "copy-with-ref",
  "displayName": "一键配置 PyCharm 风格",
  "description": "一键配置 PyCharm 风格的 VS Code 环境：Darcula 主题、JetBrains Mono 字体、文件树优化、快捷键绑定、文件引用复制等。",
  "version": "0.0.1",
  "publisher": "user",
  "repository": {
    "type": "git",
    "url": "https://github.com/HuiyangCao/vscode-copy-with-ref.git"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "keywords": ["copy", "path", "line", "reference", "clipboard"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copy-with-ref.copy",
        "title": "Copy with File Reference"
      },
{
        "command": "copy-with-ref.copyFilesToSystem",
        "title": "Copy to System Clipboard"
      },
      {
        "command": "copy-with-ref.copyFileName",
        "title": "Copy File Name"
      },
      {
        "command": "copy-with-ref.revealFolderInExplorer",
        "title": "Reveal Folder in Explorer"
      }
    ],
    "keybindings": [],
    "menus": {
      "editor/context": [
        {
          "command": "copy-with-ref.copy",
          "group": "9_cutcopypaste",
          "when": "editorTextFocus"
        }
      ],
"explorer/context": [
        {
          "command": "copy-with-ref.copyFilesToSystem",
          "group": "5_cutcopypaste",
          "when": "!explorerResourceIsRoot"
        },
        {
          "command": "copy-with-ref.copyFileName",
          "group": "5_cutcopypaste",
          "when": "!explorerResourceIsRoot"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
