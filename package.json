{
  "name": "user-extension",
  "displayName": "一键配置 PyCharm 风格",
  "description": "一键配置 PyCharm 风格的 VS Code 环境：Darcula 主题、JetBrains Mono 字体、文件树优化、快捷键绑定、文件引用复制等。",
  "version": "0.0.1",
  "publisher": "user",
  "repository": {
    "type": "git",
    "url": "https://github.com/HuiyangCao/vscode-copy-with-ref.git"
  },
  "icon": "other_files/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copy",
    "path",
    "line",
    "reference",
    "clipboard"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "user_extension.runCommand",
        "title": "Run Command"
      },
      {
        "command": "user_extension.openCommandConfig",
        "title": "Edit Config",
        "icon": "$(edit)"
      },
      {
        "command": "user_extension.refreshCommands",
        "title": "Refresh Commands",
        "icon": "$(refresh)"
      },
      {
        "command": "user_extension.newCommandConfig",
        "title": "New Command Config",
        "icon": "$(add)"
      },
      {
        "command": "user_extension.copy",
        "title": "Copy with File Reference"
      },
      {
        "command": "user_extension.copyFilesToSystem",
        "title": "Copy to System Clipboard"
      },
      {
        "command": "user_extension.copyFileName",
        "title": "Copy File Name"
      },
      {
        "command": "user_extension.revealFolderInExplorer",
        "title": "Reveal Folder in Explorer"
      },
      {
        "command": "user_extension.killPythonDebug",
        "title": "Kill All Python Debug",
        "icon": "$(close)"
      },
      {
        "command": "user_extension.addFavoriteFolder",
        "title": "Add to Favorite Folders"
      },
      {
        "command": "user_extension.deleteModelFiles",
        "title": "Delete Model Files (整理 Logs / model_*.pt)"
      },
      {
        "command": "user_extension.connectSsh",
        "title": "Open terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "user_extension.refreshSsh",
        "title": "Refresh SSH Hosts",
        "icon": "$(refresh)"
      },
      {
        "command": "user_extension.openSshConfig",
        "title": "Open SSH Config",
        "icon": "$(edit)"
      },
      {
        "command": "user_extension.syncUpload",
        "title": "Upload to Server",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "user_extension.syncDownload",
        "title": "Download from Server",
        "icon": "$(cloud-download)"
      },
      {
        "command": "user_extension.copySshIp",
        "title": "Copy SSH Host/IP",
        "icon": "$(copy)"
      },
      {
        "command": "user_extension.setSshStartCommand",
        "title": "Set SSH Startup Command",
        "icon": "$(gear)"
      },
      {
        "command": "user_extension.addBookmark",
        "title": "Add Bookmark",
        "icon": "$(add)"
      },
      {
        "command": "user_extension.removeBookmark",
        "title": "Remove Bookmark",
        "icon": "$(trash)"
      },
      {
        "command": "user_extension.openBookmark",
        "title": "Open Bookmark"
      },
      {
        "command": "user_extension.refreshWeb",
        "title": "Refresh Web Explorer",
        "icon": "$(refresh)"
      }
    ],
    "keybindings": [],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "user_extension",
          "title": "User Extension",
          "icon": "other_files/锤子.svg"
        }
      ]
    },
    "views": {
      "user_extension": [
        {
          "id": "user_extension_commands",
          "name": "Commands"
        },
        {
          "id": "user_extension_ssh",
          "name": "SSH Servers"
        },
        {
          "id": "user_extension_web",
          "name": "Explorer"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "user_extension.newCommandConfig",
          "when": "view == user_extension_commands",
          "group": "navigation"
        },
        {
          "command": "user_extension.refreshCommands",
          "when": "view == user_extension_commands",
          "group": "navigation"
        },
        {
          "command": "user_extension.refreshSsh",
          "when": "view == user_extension_ssh",
          "group": "navigation"
        },
        {
          "command": "user_extension.openSshConfig",
          "when": "view == user_extension_ssh",
          "group": "navigation"
        },
        {
          "command": "user_extension.syncUpload",
          "when": "view == user_extension_ssh && viewItem == sshHost",
          "group": "inline@1"
        },
        {
          "command": "user_extension.syncDownload",
          "when": "view == user_extension_ssh && viewItem == sshHost",
          "group": "inline@3"
        },
        {
          "command": "user_extension.addBookmark",
          "when": "view == user_extension_web",
          "group": "navigation"
        },
        {
          "command": "user_extension.refreshWeb",
          "when": "view == user_extension_web",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "user_extension.openCommandConfig",
          "when": "view == user_extension_commands && viewItem == category",
          "group": "inline"
        },
        {
          "command": "user_extension.syncDownload",
          "when": "view == user_extension_ssh && viewItem == sshHost",
          "group": "inline@1"
        },
        {
          "command": "user_extension.syncUpload",
          "when": "view == user_extension_ssh && viewItem == sshHost",
          "group": "inline@3"
        },
        {
          "command": "user_extension.connectSsh",
          "when": "view == user_extension_ssh && viewItem == sshHost",
          "group": "inline@5"
        },
        {
          "command": "user_extension.copySshIp",
          "when": "view == user_extension_ssh && viewItem == sshHost",
          "group": "navigation@1"
        },
        {
          "command": "user_extension.setSshStartCommand",
          "when": "view == user_extension_ssh && viewItem == sshHost",
          "group": "navigation@2"
        },
        {
          "command": "user_extension.removeBookmark",
          "when": "view == user_extension_web && viewItem == bookmarkItem",
          "group": "inline"
        }
      ],
      "debug/toolBar": [
        {
          "command": "user_extension.killPythonDebug",
          "when": "inDebugMode"
        }
      ],
      "editor/context": [
        {
          "command": "user_extension.copy",
          "group": "9_cutcopypaste",
          "when": "editorTextFocus"
        }
      ],
      "explorer/context": [
        {
          "command": "user_extension.copyFilesToSystem",
          "group": "5_cutcopypaste",
          "when": "!explorerResourceIsRoot"
        },
        {
          "command": "user_extension.copyFileName",
          "group": "5_cutcopypaste",
          "when": "!explorerResourceIsRoot"
        },
        {
          "command": "user_extension.addFavoriteFolder",
          "group": "navigation",
          "when": "explorerResourceIsFolder"
        },
        {
          "command": "user_extension.deleteModelFiles",
          "group": "navigation",
          "when": "explorerResourceIsFolder"
        }
      ]
    },
    "configuration": {
      "title": "User Extension",
      "properties": {
        "user_extension.deleteModelFilesFolderPurgePtLimit": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "markdownDescription": "步骤 1：直接子文件夹内 `.pt` 文件数 **严格小于** 该值时，才可能被整夹删除（还需满足 model 编号条件）。"
        },
        "user_extension.deleteModelFilesFolderPurgeModelMax": {
          "type": "number",
          "default": 4000,
          "minimum": 0,
          "markdownDescription": "步骤 1：上述子文件夹内所有 `model_*.pt` 的编号必须 **严格小于** 该值，才会被整夹删除；任一号 ≥ 该值则保留该文件夹。"
        }
      }
    }
  },
  "scripts": {
    "compile": "npm run merge && tsc -p ./other_files/tsconfig.json",
    "watch": "tsc -watch -p ./other_files/tsconfig.json",
    "merge": "node scripts/mergeContributes.js",
    "prepackage": "npm run merge"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@supermemory/tools": "^1.4.1",
    "opencode-superlocalmemory": "^0.1.2",
    "supermemory": "^4.21.1"
  }
}
